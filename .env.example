# Parallel.ai API key — get one at https://platform.parallel.ai
PARALLEL_API_KEY=your_parallel_key_here

# Optional: Slack Incoming Webhook URL. If unset, the Slack digest is written
# to ./out/slack-payload.json and printed to the console instead (demo never breaks).
# Create one at https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=

# Optional: default Task API processor (lite | base | core | pro | ultra).
# Defaults to "core" — ~10 fields, good depth/cost balance ($0.025/run).
PARALLEL_PROCESSOR=core
